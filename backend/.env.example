# Database URL.
# Default (unset) -> local SQLite file: sqlite+aiosqlite:///./court_cases.db
# For Neon/Postgres, paste the connection string. postgres:// and postgresql://
# are normalized to postgresql+asyncpg:// automatically, and ssl is enabled.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Comma-separated list of allowed CORS origins.
# Defaults to "http://localhost:3000,*" for the demo.
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# Set to "false" to skip seeding sample data on startup (default: true).
# SEED_ON_STARTUP=true
